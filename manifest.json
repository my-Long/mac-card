{
  "manifest_version": 3,
  "name": "PicBorder",
  "version": "1.0.0",
  "description": "给图片/截图加上 macOS 风格窗口边框",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
